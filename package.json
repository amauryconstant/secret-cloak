{
    "name": "secret-cloak",
    "version": "0.1.0",
    "description": "OpenCode plugin: redact secrets/PII via gitleaks before LLM requests, restore locally after",
    "keywords": [
        "gitleaks",
        "opencode",
        "opencode-plugin",
        "privacy",
        "redaction",
        "secret-cloak",
        "secrets"
    ],
    "license": "MIT",
    "files": [
        "dist",
        "secret-cloak.config.json.example"
    ],
    "type": "module",
    "main": "./dist/index.mjs",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "bun test",
        "prepack": "bun test"
    },
    "devDependencies": {
        "@types/bun": "^1.3.0",
        "@types/node": "^24.0.0",
        "bun": "^1.3.0",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.20.0",
        "tsdown": "^0.21.0",
        "typescript": "^6.0.0"
    },
    "peerDependencies": {
        "@opencode-ai/plugin": "^1.0.0"
    }
}
